@using AntennaCalibrator.View.Shared.Model
@inject IJSRuntime JS

<div id="chromosome-plot" style="width: 100%; height: 500px;"></div>

@code {
    [Parameter] public IEnumerable<GenerationChromosome> Chromosomes { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshAsync();
        }
    }

    public async Task RefreshAsync()
    {
        var colors = new[] { "28b463", "e74c3c", "3498db", "f1c40f", "8e44ad", "dc7633" };
        var range = Enumerable.Range(0, 20).Select(i => i * 5);

        var chromosomes = Chromosomes
            .Select((c, idx) =>
            {
                var color = colors[idx % colors.Length];
                var isReal = idx == 0;

                return new
                {
                    x = range,
                    y = c.Genes,
                    mode = "markers",
                    name = isReal ? "Real PCV" : $"Chr. {idx}",
                    marker = new
                    {
                        size = isReal ? 10 : 8,
                        color,
                        symbol = isReal ? "square" : "circle"
                    },
                    line = new
                    {
                        color
                    }
                };
            })
            .ToArray();

        var layout = new
        {
            xaxis = new
            {
                title = new { text = "Zenith angle" },
                tickvals = Enumerable.Range(0, 20).Select(i => i * 5).ToArray(),
                ticktext = Enumerable.Range(0, 20).Select(i => $"{i * 5}°").ToArray(),
                tickmode = "array",
                range = new[] { -2, 92 },
                dtick = 5
            },
            yaxis = new { title = new { text = "PCV [mm]" } },
            legend = new { orientation = "h", yanchor = "bottom", y = 1.02, xanchor = "right", x = 1 },
            margin = new { t = 20, l = 40, r = 20, b = 40 }
        };

        await JS.InvokeVoidAsync("plotlyInterop.plotChart", "chromosome-plot", chromosomes, layout);
    }
}